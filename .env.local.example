# Copy this to .env.local and fill in your values
# None of these are ever sent to the browser.

# Backend connection (server-side only)
ASSISTET_API_URL=http://localhost:8000
ASSISTET_API_TOKEN=your_api_token_here

# Auth — password you type on the login page
AUTH_PASSWORD=choose-a-strong-password

# Auth — long random secret for the session cookie (generate with: openssl rand -hex 32)
AUTH_TOKEN=replace-with-output-of-openssl-rand-hex-32
