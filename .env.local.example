# ─── SHARED with backend (same value in both Railway services) ────────────────
# Token that the frontend sends and the backend validates.
# Generate once: openssl rand -hex 32
APP_API_TOKEN=your-shared-api-token-here

# Backend public URL (Railway gives you this after deploying the backend service)
BACKEND_URL=http://localhost:8000

# ─── FRONTEND only ────────────────────────────────────────────────────────────
# Password for the login page
AUTH_PASSWORD=choose-a-strong-password

# Secret stored in the session cookie — must be long and random
# Generate: openssl rand -hex 32
AUTH_TOKEN=replace-with-output-of-openssl-rand-hex-32
